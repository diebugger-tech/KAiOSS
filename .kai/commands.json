{
  "nixos-check": {
    "cmd": "nixos-rebuild dry-activate --flake /etc/nixos",
    "risiko": "low",
    "beschreibung": "NixOS Konfiguration prüfen ohne Aktivierung (kein Systemeinfluss)",
    "sandbox": true
  },
  "nixos-switch": {
    "cmd": "nixos-rebuild switch --flake /etc/nixos",
    "risiko": "critical",
    "beschreibung": "NixOS Konfiguration anwenden — erfordert manuelle Freigabe",
    "sandbox": true
  },
  "git-status": {
    "cmd": "git -C /etc/nixos status",
    "risiko": "low",
    "beschreibung": "Git Status von /etc/nixos (nur lesend)",
    "sandbox": true
  },
  "git-diff": {
    "cmd": "git -C /etc/nixos diff",
    "risiko": "low",
    "beschreibung": "Git Diff von /etc/nixos (nur lesend)",
    "sandbox": true
  },
  "git-commit-test": {
    "cmd": "git -C /etc/nixos commit --allow-empty -m test",
    "risiko": "medium",
    "beschreibung": "Leerer Test-Commit in /etc/nixos — erfordert Toast-Bestätigung",
    "sandbox": true
  },
  "surreal-backup": {
    "cmd": "surreal export --conn ws://localhost:8000 --user root --pass root --ns kaioss --db kaioss",
    "risiko": "medium",
    "beschreibung": "SurrealDB kaioss-Datenbank exportieren (läuft außerhalb Sandbox)",
    "sandbox": false
  },
  "ollama-list": {
    "cmd": "ollama list",
    "risiko": "low",
    "beschreibung": "Installierte Ollama-Modelle auflisten (läuft außerhalb Sandbox)",
    "sandbox": false
  },
  "system-journal": {
    "cmd": "journalctl -n 50 --no-pager",
    "risiko": "low",
    "beschreibung": "Letzte 50 Systemlog-Einträge ausgeben",
    "sandbox": true
  }
}
